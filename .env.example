# Billiam OS — Environment Configuration
# Copy this file to ~/.config/billiam-os/.env or export these variables
#
# Usage:
#   cp .env.example ~/.config/billiam-os/.env
#   # Then edit with your values
#   source ~/.config/billiam-os/.env

# ── LLM Backend (required) ───────────────────────────────────────────────────
# Point to your local inference server (llama.cpp, Ollama, vLLM, etc.)
# Default: http://localhost:8080/v1 (llama.cpp server)
# BILLIAM_API_BASE=http://localhost:8080/v1

# Model name for the LLM (default: qwen-2.5-coder-3b-instruct)
# BILLIAM_MODEL=qwen-2.5-coder-3b-instruct

# LLM temperature (default: 0.2)
# BILLIAM_TEMPERATURE=0.2

# Max tokens per response (default: 512)
# BILLIAM_MAX_TOKENS=512

# ── Voice (optional) ─────────────────────────────────────────────────────────
# Edge TTS voice for British butler (default: en-GB-RyanNeural)
# BILLIAM_TTS_VOICE=en-GB-RyanNeural

# Whisper model size for STT (tiny, base, small, medium, large)
# Smaller = faster, larger = more accurate
# BILLIAM_STT_MODEL=base

# Wake word (default: billiam)
# BILLIAM_WAKE_WORD=billiam

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# BILLIAM_LOG_LEVEL=INFO

# ── Memory ───────────────────────────────────────────────────────────────────
# Memory storage path (default: ~/.config/billiam-os/memory.json)
# BILLIAM_MEMORY_PATH=~/.config/billiam-os/memory.json

# ── Config file path (optional) ──────────────────────────────────────────────
# BILLIAM_CONFIG=/path/to/config.yaml
